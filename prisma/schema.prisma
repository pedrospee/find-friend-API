generator client {
  provider = "prisma-client"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model Org {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  whatsapp     String
  address      String
  city         String
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("orgs")
}
