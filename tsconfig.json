{
  "compilerOptions": {
    "target": "ES2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "lib": ["ES2022"],
    "outDir": "build",
    "rootDir": ".",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["${configDir}/src/*"],
      "@/prisma-client": ["${configDir}/node_modules/.prisma/client"]
    }
  },
  "include": [
    "src/**/*",
    "prisma.config.ts"
  ]
}
